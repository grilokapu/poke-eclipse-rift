    additem(ITEM_POISON_BARB, 1)
    additem(ITEM_NEVER_MELT_ICE, 1)
    additem(ITEM_SPELL_TAG, 1)
    additem(ITEM_TWISTED_SPOON, 1)
    additem(ITEM_CHARCOAL, 1)
    additem(ITEM_DRAGON_FANG, 1)
    additem(ITEM_SILK_SCARF, 1)
    additem(ITEM_OCCA_BERRY, 50)
    additem(ITEM_PASSHO_BERRY, 50)
    additem(ITEM_WACAN_BERRY, 50)
    additem(ITEM_RINDO_BERRY, 50)
    additem(ITEM_YACHE_BERRY, 50)
    additem(ITEM_CHOPLE_BERRY, 50)
    additem(ITEM_KEBIA_BERRY, 50)
    additem(ITEM_SHUCA_BERRY, 50)
    additem(ITEM_COBA_BERRY, 50)
    additem(ITEM_PAYAPA_BERRY, 50)
    additem(ITEM_TANGA_BERRY, 50)
    additem(ITEM_CHARTI_BERRY, 50)
    additem(ITEM_KASIB_BERRY, 50)
    additem(ITEM_HABAN_BERRY, 50)
    additem(ITEM_COLBUR_BERRY, 50)
    additem(ITEM_BABIRI_BERRY, 50)
    additem(ITEM_CHILAN_BERRY, 50)
    additem(ITEM_MICLE_BERRY, 50)
    additem(ITEM_CUSTAP_BERRY, 50)
    additem(ITEM_JABOCA_BERRY, 50)
    additem(ITEM_ROWAP_BERRY, 50)
    additem(ITEM_ROSELI_BERRY, 50)
    additem(ITEM_KEE_BERRY, 50)
    additem(ITEM_MARANGA_BERRY, 50)
    setflag(FLAG_STARTER_PACK)
    closemessage
    releaseall
    end
}

script PineveilTown_PlayerVideoGamePassword_WrongPassword {
    playse(SE_FAILURE)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("Senha incorreta!\nTente novamente.", MSGBOX_DEFAULT)

        case ENGLISH_LANGUAGE:
            msgbox("Wrong password!\nPlease try again.", MSGBOX_DEFAULT)

        case SPANISH_LANGUAGE:
            msgbox("¡Contraseña incorrecta!\nInténtalo de nuevo.", MSGBOX_DEFAULT)
    }
    waitse
    closemessage
    releaseall
    end
}

script PineveilTown_PlayerRoom_Slowpoke_Doll {
    lockall
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("É um Slowpoke de pelúcia.\nEle é täo fofinho!", MSGBOX_DEFAULT)

        case ENGLISH_LANGUAGE:
            msgbox("It's a Slowpoke plush doll.\nIt's so cute!", MSGBOX_DEFAULT)

        case SPANISH_LANGUAGE:
            msgbox("Es un peluche de Slowpoke.\n¡Es tan lindo!", MSGBOX_DEFAULT)
    }
    waitstate
    closemessage
    releaseall
    end
}

script PineveilTown_PlayerRoom_TurnPlayerFaceUp_OnWarp {
    turnobject(LOCALID_PLAYER, DIR_NORTH)
    setvar(VAR_PLAYERFACING_ROOM, 2)
    end
}

script PineveilTown_PlayerRoom_Continue_RivalConversation {
    lockall
    applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
    applymovement(LOCALID_BARRY, Common_Movement_FaceLeft)
    waitmovementall
    delay(30)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "Você ouviu o que a Professora\nHikari acabou de dizer?\pAgora eu estou ainda mais animado\npara começar a nossa jornada!\pVou passar em casa rapidinho para\nme despedir da minha mäe e depois\lseguir para o laboratório da\lProfessora Hikari.\pTe encontro lá, {PLAYER}!", MSGBOX_AUTOCLOSE)
        case ENGLISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "Did you hear what Professor Hikari\njust said?\pNow I'm even more excited to start\nour journey!\pI'm going to stop by my house real\nquick to say goodbye to my mom,\land then head to Professor\lHikari's lab.\pI'll meet you there, {PLAYER}!", MSGBOX_AUTOCLOSE)
        case SPANISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "¿Escuchaste lo que acaba de decir\nla profesora Hikari?\p¡Ahora estoy aún más emocionado\npor comenzar nuestra aventura!\pVoy a pasar por mi casa un momento\npara despedirme de mi mamá y luego\liré al laboratorio de la profesora\lHikari.\p¡Te veo allí, {PLAYER}!", MSGBOX_AUTOCLOSE)
    }
    movenpc(LOCALID_BARRY, Movement_BarryLeaveRoom)
    playse(SE_PIN)
    movenpc(LOCALID_BARRY, Common_Movement_ExclamationMark)
    waitse
    delay(30)
    movenpc(LOCALID_BARRY, Movement_BarryGobackToPlayer)
    delay(30)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "A propósito, {PLAYER}…\pO seu amigo e rival de Seafood näo\nveio com você para Aetheris, veio?\pIsso significa que você vai\nprecisar de um novo rival!\pJá que nos conhecemos há bastante\ntempo, eu posso ser o seu rival\laqui.\pMas, como todo rival digno de ser\nlembrado, você deve me chamar pelo\lnome que escolher!\pEntäo… qual será o meu nome na\nsua jornada?")
        case ENGLISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "By the way, {PLAYER}…\pYour friend and rival from Seafood\ndidn't come with you to Aetheris,\ldid they?\pThat means you'll need a new\nrival!\pSince we've known each other for a\nlong time, I can be your rival\lhere.\pBut every rival worth remembering\nneeds a proper name!\pSo… what will you call me on\nyour journey?")
        case SPANISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "Por cierto, {PLAYER}…\pTu amigo y rival de Seafood no\nvino contigo a Aetheris, ¿verdad?\p¡Eso significa que necesitarás un\nnuevo rival!\pComo nos conocemos desde hace\nbastante tiempo, yo puedo ser tu\lrival aquí.\pPero todo rival digno de ser\nrecordado necesita un buen nombre.\pEntonces… ¿cómo quieres llamarme\nen tu aventura?")
    }
    callnative(EnterRivalName)
    waitstate
    delay(30)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "{RIVAL}", "Hmm…\pEntäo esse é o meu nome agora?\p{RIVAL}… Gostei! Tem um som\nforte.\pPode ter certeza, {PLAYER}!\pUm dia todo mundo na regiäo de\nAetheris vai conhecer esse nome!\pE quando isso acontecer…\pEles também väo lembrar que você\nfoi o treinador que teve a honra\lde ser meu rival!", MSGBOX_AUTOCLOSE)
        case ENGLISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "{RIVAL}", "Hmm…\pSo that's my name now?\p{RIVAL}… I like it! It has a\nstrong ring to it.\pJust wait and see, {PLAYER}!\pOne day everyone in the Aetheris\nregion will know that name!\pAnd when that happens…\pThey'll also remember that you\nwere the trainer who had the honor\lof being my rival!", MSGBOX_AUTOCLOSE)
        case SPANISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "{RIVAL}", "Mmm…\p¿Así que ese es mi nombre ahora?\p{RIVAL}… ¡Me gusta! Suena\nfuerte.\p¡Ya verás, {PLAYER}!\p¡Un día todos en la región de\nAetheris conocerán ese nombre!\pY cuando eso pase…\p¡También recordarán que tú fuiste\nel entrenador que tuvo el honor de\lser mi rival!", MSGBOX_AUTOCLOSE)
    }
    movenpc(LOCALID_BARRY, Movement_BarryLeaveRoom)
    delay(30)
    removeobject(LOCALID_BARRY)
    setflag(FLAG_BARRY_IS_RIVAL)
    setvar(VAR_PLAYER_ROOM_2F_TILE, 3)
    releaseall
    end
}

movement Movement_BarryMovesToPlayersBed {
    walk_left
    face_left
}

movement Movement_PlayerLookBarry {
    face_left
}

movement Movement_PlayerStopsLookingBarry {
    face_right
    emote_exclamation_mark
}

movement Movement_PlayerStepbackwards {
    walk_left
    face_right
}

movement Movement_BarrySmileToPlayer {
    emote_heart
}

movement Movement_PlayerGotoTV {
    walk_down
    walk_left * 3
    face_up
}

movement Movement_BarryGotoTV {
    walk_left
    walk_down
    walk_left * 2
    face_up
}

movement Movement_BarryLeaveRoom {
    walk_right * 3
    walk_up
    face_right
}

movement Movement_BarryGobackToPlayer {
    walk_down
    walk_left * 3
    face_left
}
