mapscripts LittlerootTown_MaysHouse_2F_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_PLAYERFACING_ROOM) >= 1) {
            setobjectxyperm(LOCALID_BARRY, 3, 4)
            setobjectmovementtype(LOCALID_BARRY, MOVEMENT_TYPE_FACE_UP)
            end
        }      
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
        VAR_PLAYERFACING_ROOM, 1: PineveilTown_PlayerRoom_TurnPlayerFaceUp_OnWarp
    ]
    MAP_SCRIPT_ON_FRAME_TABLE [
        VAR_PLAYER_ROOM_2F_TILE, 2: PineveilTown_PlayerRoom_Continue_RivalConversation
    ]
}

const PSS_ICON_BARRY = 1

script PineveilTown_PlayerHouse_2F_Rival_Tile {
    lockall
    playse(SE_PIN)
    moveplayer(Movement_PlayerStopsLookingBarry)
    waitse
    fadescreen(FADE_TO_BLACK)
    playse(SE_EXIT)
    setobjectxy(LOCALID_BARRY, 7, 3)
    fadescreen(FADE_FROM_BLACK)
    applymovement(LOCALID_BARRY, Movement_BarryMovesToPlayersBed)
    applymovement(LOCALID_PLAYER, Movement_PlayerStepbackwards)
    waitmovementall
    delay(30)
    callnative(CheckGenderString)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "Nossa, {PLAYER}! Ainda bem que\nvocê já está acordad{STR_VAR_1}!\pFiquei sabendo que você também\ntinha chegado à regiäo de\lAetheris.\pDepois que saí da regiäo de\nSeafood, fui para Sinnoh. Porém,\llogo descobri que em Aetheris\ltambém iria começar a Liga Pokémon\lda regiäo.\pCoincidentemente, também ouvi\ndizer que você estaria por aqui.", MSGBOX_AUTOCLOSE)

        case ENGLISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "Wow, {PLAYER}! I'm glad you're\nalready awake!\pI heard that you had also arrived\nin the Aetheris region.\pAfter leaving the Seafood region,\nI went to Sinnoh. But soon after,\lI found out that the Pokémon\lLeague in Aetheris was about to\lbegin as well.\pCoincidentally, I also heard that\nyou would be here.", MSGBOX_AUTOCLOSE)

        case SPANISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "¡Vaya, {PLAYER}! ¡Qué bueno que ya\nestés despierto!\pEscuché que tú también habías\nllegado a la región de Aetheris.\pDespués de salir de la región de\nSeafood, fui a Sinnoh. Pero poco\ldespués me enteré de que la Liga\lPokémon de Aetheris también estaba\lpor comenzar.\pCoincidentemente, también escuché\nque estarías por aquí.", MSGBOX_AUTOCLOSE)
    }
    playse(SE_PIN)
    movenpc(LOCALID_BARRY, Movement_BarrySmileToPlayer)
    waitse
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "A propósito, a professora Hikari\nvai entrar ao vivo na TV agora\lmesmo.\pVamos assistir um pouco. Acho que\nvai ser interessante.", MSGBOX_AUTOCLOSE)

        case ENGLISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "By the way, Professor Hikari is\nabout to appear live on TV right\lnow.\pLet's watch for a bit. I think it\nwill be interesting.", MSGBOX_AUTOCLOSE)
        
        case SPANISH_LANGUAGE:
            msgminibox(PSS_ICON_BARRY, "Barry", "Por cierto, la profesora Hikari\nestá a punto de aparecer en la TV\len vivo ahora mismo.\pVamos a ver un poco. Creo que será\ninteresante.", MSGBOX_AUTOCLOSE)
    }
    applymovement(LOCALID_PLAYER, Movement_PlayerGotoTV)
    applymovement(LOCALID_BARRY, Movement_BarryGotoTV)
    waitmovementall
    playse(SE_CLICK)
    setmetatile(2, 2, METATILE_DW_PlayerHouse_TV_1, 1)
    setmetatile(3, 2, METATILE_DW_PlayerHouse_TV_2, 1)
    setmetatile(2, 3, METATILE_DW_PlayerHouse_TV_3, 1)
    setmetatile(3, 3, METATILE_DW_PlayerHouse_TV_4, 1)
    special(DrawWholeMapView)
    waitse
    delay(45)
    setvar(VAR_PLAYER_ROOM_2F_TILE, 1)
    setflag(FLAG_SPAWN_INVISIBLE)
    warpsilent(MAP_LITTLEROOT_TOWN, 13, 8)
    release
    end
}

script PineveilTown_Player_PC {
    lockall
    setvar(VAR_0x8004, PC_LOCATION_BRENDANS_HOUSE)
	special(DoPCTurnOnEffect)
	playse(SE_PC_ON)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox ("{PLAYER} ligou o PC.$", MSGBOX_DEFAULT)

        case ENGLISH_LANGUAGE:
            msgbox ("{PLAYER} booted up the PC.$", MSGBOX_DEFAULT)

        case SPANISH_LANGUAGE:
	        msgbox ("{PLAYER} encendió la PC.$", MSGBOX_DEFAULT)
    }
	special(BedroomPC)
	waitstate
	releaseall
	end
}

script PineveilTown_TurnOffPlayer_PC {
	setvar(VAR_0x8004, PC_LOCATION_BRENDANS_HOUSE)
	playse(SE_PC_OFF)
	special(DoPCTurnOffEffect)
	releaseall
	end
}

script PineveilTown_PlayerVideoGamePassword {
    lockall
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("É um Wii!\nEle é controlado por um Wii Remote!", MSGBOX_DEFAULT)

        case ENGLISH_LANGUAGE:
            msgbox("It's a Wii!\nIt's controlled by a Wii Remote!", MSGBOX_DEFAULT)

        case SPANISH_LANGUAGE:
            msgbox("Es un Wii!\nEstá controlado por un mando Wii!", MSGBOX_DEFAULT)
    }
    special(EnterCode)
    waitstate
    special(GetCodeFeedback)
    switch(var(VAR_RESULT)) {
        case 0:
            goto(PineveilTown_PlayerVideoGamePassword_QuickBalls)
        case 1:
            goto(PineveilTown_PlayerVideoGamePassword_InfiniteRepel)
        case 2:
            goto(PineveilTown_PlayerVideoGamePassword_RareCandy)
        case 3:
            goto(PineveilTown_PlayerVideoGamePassword_StartPack)
    }
    goto(PineveilTown_PlayerVideoGamePassword_WrongPassword)
}

script PineveilTown_PlayerVideoGamePassword_QuickBalls {
    playse(SE_SUCCESS)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("Senha correta!\nVocê recebeu 10 Quick Balls!", MSGBOX_DEFAULT)

        case ENGLISH_LANGUAGE:
            msgbox("Correct password!\nYou received 10 Quick Balls!", MSGBOX_DEFAULT)

        case SPANISH_LANGUAGE:
            msgbox("¡Contraseña correcta!\n¡Has recibido 10 Quick Balls!", MSGBOX_DEFAULT)
    }
    waitse
    additem(ITEM_QUICK_BALL, 10)
    closemessage
    releaseall
    end
}

script SystemScript_Infinite_Repel_Off {
    lockall
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("Você gostaria de desativar o\nUltra Repel?", MSGBOX_YESNO)

        case ENGLISH_LANGUAGE:
            msgbox("Would you like to disable the\nUltra Repel?", MSGBOX_YESNO)

        case SPANISH_LANGUAGE:
            msgbox("¿Quieres desactivar el\nUltra Repel?", MSGBOX_YESNO)
    }
    if (var(VAR_RESULT) == FALSE)
    {
        goto(EndScript)
    }
    clearflag(FLAG_NO_RANDOM_WILD_ENCOUNTERS)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("Ultra Repel desativado!", MSGBOX_DEFAULT)
        case ENGLISH_LANGUAGE:
            msgbox("Ultra Repel disabled!", MSGBOX_DEFAULT)
        case SPANISH_LANGUAGE:
            msgbox("¡Ultra Repel desactivado!", MSGBOX_DEFAULT)
    }
    goto(EndScript)
}

script SystemScript_Infinite_Repel_On {
    lockall
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("Você gostaria de ativar o\nUltra Repel?", MSGBOX_YESNO)

        case ENGLISH_LANGUAGE:
            msgbox("Would you like to enable the\nUltra Repel?", MSGBOX_YESNO)

        case SPANISH_LANGUAGE:
            msgbox("¿Quieres activar el\nUltra Repel?", MSGBOX_YESNO)
    }
    if (var(VAR_RESULT) == FALSE)
    {
        goto(EndScript)
    }
    setflag(FLAG_NO_RANDOM_WILD_ENCOUNTERS)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("Ultra Repel ativado!", MSGBOX_DEFAULT)
        case ENGLISH_LANGUAGE:
            msgbox("Ultra Repel enabled!", MSGBOX_DEFAULT)
        case SPANISH_LANGUAGE:
            msgbox("¡Ultra Repel activado!", MSGBOX_DEFAULT)
    }
    goto(EndScript)
}

script EndScript {
    releaseall
    end
}

script PineveilTown_PlayerVideoGamePassword_InfiniteRepel {
    goto_if_set(FLAG_RECEIVED_ULTRA_REPEL, PineveilTown_PlayerVideoGamePassword_AlreadyReceived)
    playse(SE_SUCCESS)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("Senha correta!\nVocê recebeu um Ultra Repel!", MSGBOX_DEFAULT)

        case ENGLISH_LANGUAGE:
            msgbox("Correct password!\nYou received an Ultra Repel!", MSGBOX_DEFAULT)

        case SPANISH_LANGUAGE:
            msgbox("¡Contraseña correcta!\n¡Has recibido un Ultra Repel!", MSGBOX_DEFAULT)
    }
    waitse
    additem(ITEM_ULTRA_REPEL, 1)
    closemessage
    setflag(FLAG_RECEIVED_ULTRA_REPEL)
    releaseall
    end
}

script PineveilTown_PlayerVideoGamePassword_AlreadyReceived {
    playse(SE_FAILURE)
    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("Você já recebeu este prêmio antes.\nNäo pode receber novamente!", MSGBOX_DEFAULT)

        case ENGLISH_LANGUAGE:
            msgbox("You have already received this\nprize. You can't receive it again!", MSGBOX_DEFAULT)

        case SPANISH_LANGUAGE:
            msgbox("Ya has recibido este premio.\n¡No puedes recibirlo otra vez!", MSGBOX_DEFAULT)
    }
    waitse
    closemessage
    releaseall
    end
}

