    switch(var(VAR_LANGUAGE)) {
        case PORTUGUESE_LANGUAGE:
            msgbox("Senha correta!\nVocê recebeu um Pacote de Itens!", MSGBOX_DEFAULT)

        case ENGLISH_LANGUAGE:
            msgbox("Correct password!\nYou received a Pack of Items!", MSGBOX_DEFAULT)

        case SPANISH_LANGUAGE:
            msgbox("¡Contraseña correcta!\n¡Has recibido un Pacote de Itens!", MSGBOX_DEFAULT)
