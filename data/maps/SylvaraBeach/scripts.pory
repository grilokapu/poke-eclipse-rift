mapscripts SylvaraBeach_MapScripts {
    
}

script SylvaraBeach_EventScript_Psychic_Battle {
    switch(var(VAR_LANGUAGE)) {
        case PT:
            trainerbattle_single(TRAINER_PSYCHIC_M_LAWRENCE, "Você é um pouco psicodélico\nigual a mim?\pVem fazer o teste!", "Parece que você me venceu na\npsicodelia!")
            msgbox("Será que um psicodélico pode\nevoluir para um psicopata?")
        case EN:
            trainerbattle_single(TRAINER_PSYCHIC_M_LAWRENCE, "Are you a little psychedelic\nlike me?\pCome take the test!", "It looks like you beat me at\npsychedelia!")
            msgbox("Can a psychedelic\nbecome a psychopath?")
        case ES:
            trainerbattle_single(TRAINER_PSYCHIC_M_LAWRENCE, "¿Eres un poco psicodélico\ncomo yo?\p¡Ven a hacer la prueba!", "¡Parece que me venciste en\npsicodelia!")
            msgbox("¿Puede un psicodélico\nconvertirse en psicópata?")
    }
    release
    end
}

script SylvaraBeach_EventScript_Rival_Battle {
    lockall
    faceplayer
    removeowe
    playbgm(MUS_RG_ENCOUNTER_RIVAL, 1)
    playse(SE_PIN)
    movenpc(VAR_LAST_TALKED, Common_Movement_ExclamationMark)
    waitse
    pause(10)
    switch(var(VAR_LANGUAGE)) {
        case PT:
            msgminibox(PSS_ICON_LUCIEN, "{RIVAL}", "Ei, {PLAYER}, ainda bem que você\nchegou!\pEu estava aproveitando a vista da\nPraia Sylvara antes de seguir em\lfrente.\pÉ um lugar tranquilo… perfeito\npara colocar os pensamentos em\lordem.\pPara ser sincero, tive alguns\npressentimentos estranhos ontem.\pNão sei explicar muito bem, mas\nparecia que algo importante estava\lprestes a acontecer.\pAinda assim, não quero deixar isso\nme distrair.\pNossa jornada está apenas\ncomeçando, e quero aproveitar cada\lmomento dela.\pQuero me tornar mais forte,\nconhecer novos Pokémon e descobrir\ltudo o que Aetheris tem a\loferecer.\pE acho que existe uma ótima\nmaneira de dar o primeiro passo.\pQue tal uma batalha entre nós\ndois?\pVamos ver o quanto aprendemos até\nagora!", MSGBOX_AUTOCLOSE)
            goto(SylvaraBeach_EventScript_Rival_Battle_PT)
        case EN:
            msgminibox(PSS_ICON_LUCIEN, "{RIVAL}", "Hey, {PLAYER}, I'm glad you made\nit!\pI was taking a moment to enjoy the\nview of Sylvara Beach before\lmoving on.\pIt's a peaceful place… perfect for\nclearing your thoughts.\pTo be honest, I had some strange\nfeelings yesterday.\pI can't really explain them, but\nit felt like something important\lwas about to happen.\pEven so, I don't want to let that\ndistract me.\pOur journey is only beginning, and\nI want to make the most of every\lmoment.\pI want to grow stronger, meet new\nPokémon, and discover everything\lAetheris has to offer.\pAnd I think there's a great way to\ntake the first step.\pHow about a battle between the two\nof us?\pLet's see how much we've learned\nso far!", MSGBOX_AUTOCLOSE)
            goto(SylvaraBeach_EventScript_Rival_Battle_EN)
        case ES:
            msgminibox(PSS_ICON_LUCIEN, "{RIVAL}", "¡Hola, {PLAYER}! ¡Qué bueno que\nllegaste!\pEstaba disfrutando la vista de la\nPlaya Sylvara antes de continuar\lmi camino.\pEs un lugar tranquilo… perfecto\npara ordenar los pensamientos.\pPara ser sincero, ayer tuve\nalgunos presentimientos extraños.\pNo sabría explicarlo, pero sentía\nque algo importante estaba por\lsuceder.\pAun así, no quiero dejar que eso\nme distraiga.\pNuestra aventura apenas está\ncomenzando, y quiero aprovechar\lcada instante.\pQuiero volverme más fuerte,\nconocer nuevos Pokémon y descubrir\ltodo lo que Aetheris tiene para\lofrecer.\pY creo que hay una excelente forma\nde dar el primer paso.\p¿Qué te parece una batalla entre\nnosotros?\p¡Veamos cuánto hemos aprendido\nhasta ahora!", MSGBOX_AUTOCLOSE)
            goto(SylvaraBeach_EventScript_Rival_Battle_ES)
    }
    release
    end
}

script SylvaraBeach_EventScript_Rival_Battle_PT {
    if (flag(FLAG_ADVENTURE_IS_MONOTYPE)) {
        trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH, "Impressionante… você está ficando\ncada vez mais forte!", "Heh, desta vez eu levei a melhor!", SylvaraBeach_EventScript_Rival_Continue)
    }
    switch(var(VAR_STORE_FIST_MON_TYPE)) {
        case TYPE_WATER:
            trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH_GRASS, "Impressionante… você está ficando\ncada vez mais forte!", "Heh, desta vez eu levei a melhor!", SylvaraBeach_EventScript_Rival_Continue)
        case TYPE_FIRE:
            trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH_WATER, "Impressionante… você está ficando\ncada vez mais forte!", "Heh, desta vez eu levei a melhor!", SylvaraBeach_EventScript_Rival_Continue)
        case TYPE_GRASS:
            trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH_FIRE, "Impressionante… você está ficando\ncada vez mais forte!", "Heh, desta vez eu levei a melhor!", SylvaraBeach_EventScript_Rival_Continue)
    }
    trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH, "Impressionante… você está ficando\ncada vez mais forte!", "Heh, desta vez eu levei a melhor!", SylvaraBeach_EventScript_Rival_Continue)
    release
    end
}

