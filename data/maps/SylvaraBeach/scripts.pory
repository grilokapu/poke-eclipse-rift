    if (flag(FLAG_ADVENTURE_IS_MONOTYPE)) {
        trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH, "Impressive… you're getting stronger\nevery time!", "Heh, looks like I got the better\nof you this time!", SylvaraBeach_EventScript_Rival_Continue)
    }
    switch(var(VAR_STORE_FIST_MON_TYPE)) {
        case TYPE_WATER:
            trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH_GRASS, "Impressive… you're getting stronger\nevery time!", "Heh, looks like I got the better\nof you this time!", SylvaraBeach_EventScript_Rival_Continue)
        case TYPE_FIRE:
            trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH_WATER, "Impressive… you're getting stronger\nevery time!", "Heh, looks like I got the better\nof you this time!", SylvaraBeach_EventScript_Rival_Continue)
        case TYPE_GRASS:
            trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH_FIRE, "Impressive… you're getting stronger\nevery time!", "Heh, looks like I got the better\nof you this time!", SylvaraBeach_EventScript_Rival_Continue)
    }
    trainerbattle_continue_lost(TRAINER_RIVAL_SYLVARA_BEACH, "Impressive… you're getting stronger\nevery time!", "Heh, looks like I got the better\nof you this time!", SylvaraBeach_EventScript_Rival_Continue)
    release
    end
}

