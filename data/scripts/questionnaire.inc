	waitmovement 0
	switch VAR_LANGUAGE
	case PT, Questionnaire_EventScript_ThankYouPt
	case ES, Questionnaire_EventScript_ThankYouEs
	case EN, Questionnaire_EventScript_ThankYouEn
Questionnaire_EventScript_ThankYouEn:
